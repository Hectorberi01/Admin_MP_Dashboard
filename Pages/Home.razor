@page "/"
@inject IAdminApi Api
@inject NavigationManager Nav

<PageTitle>Vue d'ensemble — Console Admin</PageTitle>

<PageHeader Title="Vue d'ensemble" Subtitle="Pilotage de la marketplace." />

@if (loadError is not null)
{
    <ErrorNotice Title="Tableau de bord indisponible" Message="@loadError" OnRetry="Reload" />
}
else if (sellers is null)
{
    <p class="mp-caption">Chargement…</p>
}
else
{
    <div class="kpi-grid">
        @foreach (var stat in BuildKpis())
        {
            <StatCard Stat="stat" />
        }
    </div>

    <MpCard Title="Vendeurs à valider" Subtitle="KYB en attente ou en revue">
        <HeaderContent>
            <MpButton Variant="ButtonVariant.Tertiary" OnClick="@(() => Nav.NavigateTo("vendeurs"))">Tout voir →</MpButton>
        </HeaderContent>
        <ChildContent>
            @{ var pending = sellers.Where(s => s.KybStatus is "InReview" or "NotStarted" or "Pending").Take(6).ToList(); }
            @if (pending.Count == 0)
            {
                <p class="mp-caption">Aucun vendeur en attente de validation. 🎉</p>
            }
            else
            {
                <div class="recent-list">
                    @foreach (var s in pending)
                    {
                        <div class="recent-row">
                            <span class="recent-cust">@s.ShopName</span>
                            <div class="recent-side">
                                <MpBadge Variant="BadgeVariant.Neutral">@s.KybStatus</MpBadge>
                                <MpButton Variant="ButtonVariant.Primary" OnClick="@(() => Nav.NavigateTo("vendeurs"))">Examiner</MpButton>
                            </div>
                        </div>
                    }
                </div>
            }
        </ChildContent>
    </MpCard>
}

<style>
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--mp-space-4); margin-bottom: var(--mp-space-6); }
    .recent-list { display: flex; flex-direction: column; }
    .recent-row { display: flex; align-items: center; justify-content: space-between; gap: var(--mp-space-4); padding: var(--mp-space-3) 0; border-bottom: 0.5px solid var(--mp-border); }
    .recent-row:last-child { border-bottom: 0; }
    .recent-cust { font-weight: 500; }
    .recent-side { display: flex; align-items: center; gap: var(--mp-space-3); }
</style>

@code {
    private IReadOnlyList<AdminSeller>? sellers;
    private string? loadError;

    protected override Task OnInitializedAsync() => Reload();

    private async Task Reload()
    {
        loadError = null; sellers = null;
        try { sellers = await Api.ListSellersAsync(); }
        catch (Exception ex) { loadError = ex.Message; }
    }

    private IEnumerable<KpiStat> BuildKpis()
    {
        if (sellers is null) yield break;
        var active = sellers.Count(s => s.Status == "Active");
        var pendingKyb = sellers.Count(s => s.KybStatus is "InReview" or "NotStarted" or "Pending");
        var avgRate = sellers.Count > 0 ? sellers.Average(s => s.CommissionRate) : 0m;

        yield return new KpiStat { Label = "Vendeurs", Value = sellers.Count.ToString(), Sublabel = $"{active} actifs", Icon = "🏪" };
        yield return new KpiStat { Label = "KYB à valider", Value = pendingKyb.ToString(), Sublabel = "en attente", Icon = "📋" };
        yield return new KpiStat { Label = "Vendeurs actifs", Value = active.ToString(), Sublabel = "boutiques ouvertes", Icon = "✅" };
        yield return new KpiStat { Label = "Commission moyenne", Value = $"{avgRate * 100:0.0} %", Sublabel = "tous vendeurs", Icon = "💰" };
    }
}
