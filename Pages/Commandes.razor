@page "/commandes"
@inject IAdminApi Api

<PageTitle>Commandes — Console Admin</PageTitle>

<PageHeader Title="Commandes" Subtitle="@(orders is null ? "Chargement…" : $"{orders.Count} commandes de la plateforme")" />

@if (loadError is not null) { <ErrorNotice Title="Commandes indisponibles" Message="@loadError" OnRetry="Reload" /> }
else if (orders is null) { <p class="mp-caption">Chargement…</p> }
else if (orders.Count == 0) { <MpCard><ChildContent><p class="mp-caption">Aucune commande.</p></ChildContent></MpCard> }
else
{
    <MpCard NoPadding="true">
        <ChildContent>
            <table class="mp-table">
                <thead><tr><th>Référence</th><th>Date</th><th>Articles</th><th>Statut</th><th class="mp-num">Total</th></tr></thead>
                <tbody>
                    @foreach (var o in orders)
                    {
                        <tr>
                            <td class="cell-strong">@o.Reference</td>
                            <td>@o.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="mp-num">@o.ItemCount</td>
                            <td><MpBadge Variant="@StatusVariant(o.Status)">@o.Status</MpBadge></td>
                            <td class="mp-num">@o.GrandTotal.ToString("N0") XOF</td>
                        </tr>
                    }
                </tbody>
            </table>
        </ChildContent>
    </MpCard>
}

@code {
    private IReadOnlyList<AdminOrder>? orders;
    private string? loadError;

    protected override Task OnInitializedAsync() => Reload();

    private async Task Reload()
    {
        loadError = null; orders = null;
        try { orders = await Api.ListOrdersAsync(); }
        catch (Exception ex) { loadError = ex.Message; }
    }

    private static BadgeVariant StatusVariant(string s) => s switch
    {
        "Paid" or "Confirmed" or "Delivered" => BadgeVariant.Verified,
        "Cancelled" => BadgeVariant.Rupture,
        "Pending" or "AwaitingPayment" => BadgeVariant.Promo,
        _ => BadgeVariant.Neutral
    };
}
